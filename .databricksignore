# OntoBricks — files excluded from Databricks bundle sync
# Only runtime-essential files should be deployed:
#   src/          — application code
#   docs/         — Help Center markdown + assets (/api/help/docs/*)
#   app.yaml      — Databricks Apps runtime config
#   run.py        — entry point
#   pyproject.toml / uv.lock / requirements.txt — dependency resolution

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/

# ── Python build artifacts ────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# ── Git / IDE / CI ────────────────────────────────────────────
.git/
.github/
.vscode/
.cursor/
.databricks/

# ── Tests & coverage ─────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
tests/

# ── Local session, logs & databases ──────────────────────────
fastapi_session/
logs/
*.pid
.ontobricks.pid
.ontobricks.log
mlflow.db

# ── Documentation ─────────────────────────────────────────────
# Ship Help Center sources (docs/*.md, images/, screenshots/) at runtime.
# Exclude Sphinx HTML build output (local/CI only).
docs/sphinx/_build/
docs/sphinx/.doctrees/
data/
licenses/
dab/
documentation.html

# ── DAB config (not needed at runtime) ───────────────────────
databricks.yml
.databricksignore

# ── Old app directory (replaced by back/, front/, shared/) ──
src/app-ARCHIVE/
app-ARCHIVE/

# ── MCP server (has its own source_code_path) ────────────────
src/mcp-server/

# ── OS / editor artifacts ────────────────────────────────────
.DS_Store
.env
.env.example

# ── Dev / deployment scripts & tooling ───────────────────────
Makefile
pytest.ini
scripts/
.cursorrules
.gitignore
LICENSE

# ── Internal-only docs / repo meta (not shipped) ────────────
# WARNING: do NOT use a bare "internal/" pattern here — it would
# also match src/api/routers/internal/, which is a required module
# and its absence breaks app startup (ModuleNotFoundError).
AGENTS.md
CLAUDE.md
CONTRIBUTING.md
README.md
SECURITY.md
releases/
.claude/
